  <!-- ==========================================
       MALTG MASTER ONTOLOGY — MALTG_onto.owl
       Multi-layer Architecture Ledger
       Technology Governance
       Version: 2.4.0
       ========================================== -->

  <owl:Ontology rdf:about="http://maltg.arch/onto">
    <rdfs:label>MALTG Master Ontology — LegalTech Edition</rdfs:label>
    <rdfs:comment>Ontología Maestra para la Arquitectura MALTG — Foundation Layer (TOGAF + COBIT + NIST), Technology Integration Layer (IA, Blockchain, Open Data, Security) y LegalTech Domain Layer (Contract Lifecycle, eDiscovery, DLT Notarization, Regulatory Compliance, Smart Legal Contracts)</rdfs:comment>
    <owl:versionInfo>3.0.0-legaltech</owl:versionInfo>
  </owl:Ontology>

  <!-- ==========================================
       ANNOTATION PROPERTIES
       Visual metadata for dashboard rendering
       ========================================== -->

  <owl:AnnotationProperty rdf:about="http://maltg.arch/onto#layer">
    <rdfs:label>layer</rdfs:label>
    <rdfs:comment>Visual layer type: core | togaf | cobit | nist | ai | blockchain | opendata | security</rdfs:comment>
  </owl:AnnotationProperty>

  <owl:AnnotationProperty rdf:about="http://maltg.arch/onto#radius">
    <rdfs:label>node radius</rdfs:label>
    <rdfs:comment>Visual node radius in pixels (integer)</rdfs:comment>
  </owl:AnnotationProperty>

  <owl:AnnotationProperty rdf:about="http://maltg.arch/onto#description">
    <rdfs:label>description</rdfs:label>
    <rdfs:comment>Human-readable description shown in tooltips</rdfs:comment>
  </owl:AnnotationProperty>

  <owl:AnnotationProperty rdf:about="http://maltg.arch/onto#score">
    <rdfs:label>maturity score</rdfs:label>
    <rdfs:comment>Implementation maturity score (0-100)</rdfs:comment>
  </owl:AnnotationProperty>

  <owl:AnnotationProperty rdf:about="http://maltg.arch/onto#weight">
    <rdfs:label>relationship weight</rdfs:label>
    <rdfs:comment>Strength of the relationship (float)</rdfs:comment>
  </owl:AnnotationProperty>

