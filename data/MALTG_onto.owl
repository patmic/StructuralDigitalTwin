  <!-- ==========================================
       LEGALTECH DOMAIN LAYER
       Specific legal-technology concepts that
       justify the LegalTech framing of the paper.
       All classes are linked back to Foundation
       and Technology Integration layers via
       Object Properties below.
       ========================================== -->

  <owl:Class rdf:about="http://maltg.arch/onto#LegalTech_Domain">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#Technology_Integration_Layer"/>
    <rdfs:label>LegalTech Domain</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>16</maltg:radius>
    <maltg:description>Capa de dominio LegalTech: conceptos específicos de tecnología jurídica que integran los frameworks de gobernanza con las necesidades del sector legal</maltg:description>
    <maltg:score>72</maltg:score>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#Contract_Lifecycle_Management">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>Contract Lifecycle Mgmt</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>10</maltg:radius>
    <maltg:description>Gestión del ciclo de vida contractual: redacción, negociación, firma electrónica, monitoreo de obligaciones y renovación automatizada</maltg:description>
    <maltg:score>78</maltg:score>
    <maltg:regulation>eIDAS Regulation (EU) 910/2014</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#eDiscovery_Pipeline">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>eDiscovery Pipeline</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>10</maltg:radius>
    <maltg:description>Descubrimiento electrónico asistido por IA: ingesta documental, clasificación predictiva de relevancia, detección de privilegio attorney-client, exportación EDRM</maltg:description>
    <maltg:score>68</maltg:score>
    <maltg:regulation>EDRM Electronic Discovery Reference Model</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#Legal_DLT_Notarization">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>Legal DLT Notarization</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>10</maltg:radius>
    <maltg:description>Notarización legal sobre DLT: timestamping con valor probatorio, cadena de custodia inmutable, hash de documentos en blockchain con certificación notarial</maltg:description>
    <maltg:score>65</maltg:score>
    <maltg:regulation>eIDAS Art. 41 — Electronic Time Stamps</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#Regulatory_Compliance_Engine">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>Regulatory Compliance Engine</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>12</maltg:radius>
    <maltg:description>Motor de cumplimiento normativo multi-regulación: evaluación continua contra GDPR, eIDAS, Directiva NIS2, normativas sectoriales y códigos deontológicos</maltg:description>
    <maltg:score>74</maltg:score>
    <maltg:regulation>GDPR (EU) 2016/679 · NIS2 Directive 2022/2555</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#GDPR_Compliance">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#Regulatory_Compliance_Engine"/>
    <rdfs:label>GDPR Compliance</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>8</maltg:radius>
    <maltg:description>Conformidad con el Reglamento General de Protección de Datos: consentimiento, derechos de los interesados, DPO, evaluaciones DPIA y transferencias internacionales</maltg:description>
    <maltg:score>76</maltg:score>
    <maltg:regulation>GDPR (EU) 2016/679</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#eIDAS_Compliance">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#Regulatory_Compliance_Engine"/>
    <rdfs:label>eIDAS Compliance</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>8</maltg:radius>
    <maltg:description>Conformidad eIDAS: firma electrónica cualificada (QES), sello electrónico, identidad digital (eID) y servicios de confianza reconocidos en la UE</maltg:description>
    <maltg:score>70</maltg:score>
    <maltg:regulation>eIDAS (EU) 910/2014 · eIDAS 2.0 (EU) 2024/1183</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#NIS2_Compliance">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#Regulatory_Compliance_Engine"/>
    <rdfs:label>NIS2 Compliance</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>8</maltg:radius>
    <maltg:description>Conformidad con la Directiva NIS2: medidas de ciberseguridad para entidades esenciales e importantes, gestión de incidentes, cadena de suministro y supervisión</maltg:description>
    <maltg:score>62</maltg:score>
    <maltg:regulation>NIS2 Directive 2022/2555</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#Attorney_Client_Confidentiality">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>Attorney-Client Privilege</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>10</maltg:radius>
    <maltg:description>Protección del secreto profesional attorney-client en entornos cloud y IA: cifrado extremo a extremo, aislamiento de datos privilegiados, controles de acceso basados en materia</maltg:description>
    <maltg:score>80</maltg:score>
    <maltg:regulation>Bar Association Ethics Rules · ABA Model Rule 1.6</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#Smart_Legal_Contracts">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>Smart Legal Contracts</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>10</maltg:radius>
    <maltg:description>Contratos legales inteligentes: fusión de texto jurídico natural con código de smart contract ejecutable, oráculos legales, resolución automatizada de disputas</maltg:description>
    <maltg:score>58</maltg:score>
    <maltg:regulation>UNIDROIT Principles · LegalDocML / Akoma Ntoso</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#Legal_Knowledge_Base">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>Legal Knowledge Base</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>9</maltg:radius>
    <maltg:description>Base de conocimiento jurídico: repositorio estructurado de jurisprudencia, normativa, doctrine y precedentes, con recuperación semántica y razonamiento legal</maltg:description>
    <maltg:score>71</maltg:score>
    <maltg:regulation>ECLI — European Case Law Identifier · EuroVoc Thesaurus</maltg:regulation>
  </owl:Class>

  <owl:Class rdf:about="http://maltg.arch/onto#Court_System_Integration">
    <rdfs:subClassOf rdf:resource="http://maltg.arch/onto#LegalTech_Domain"/>
    <rdfs:label>Court System Integration</rdfs:label>
    <maltg:layer>legaltech</maltg:layer>
    <maltg:radius>9</maltg:radius>
    <maltg:description>Integración con sistemas judiciales: presentación electrónica de escritos (e-filing), notificaciones judiciales electrónicas, acceso a registros públicos y APIs de tribunales</maltg:description>
    <maltg:score>55</maltg:score>
    <maltg:regulation>EU e-Justice Portal · national court APIs</maltg:regulation>
  </owl:Class>

